NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/bounty_board
DATABASE_NAME=bounty_board
MONGODB_MAX_RETRIES=5
MONGODB_RETRY_DELAY_MS=2000
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=0
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_CONNECT_TIMEOUT_MS=10000
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace_with_smtp_username
SMTP_PASS=replace_with_smtp_password
SMTP_FROM="F.A.S.T. DLI Platform <no-reply@example.com>"
